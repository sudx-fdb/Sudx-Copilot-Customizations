{
  "hooks": {
    "UserPromptSubmit": [
      {
        "type": "command",
        "windows": "powershell -ExecutionPolicy Bypass -NoProfile -File .github/hooks/scripts/workflow-selector.ps1",
        "linux": "bash .github/hooks/scripts/workflow-selector.sh",
        "osx": "bash .github/hooks/scripts/workflow-selector.sh",
        "timeout": 5
      }
    ]
  }
}
