{
  "$schema_version": 1,
  "_comment": "Example MCP server configuration. Copy to mcp_servers.json and adjust values.",
  "servers": {
    "example-docker-server": {
      "enabled": true,
      "install_method": "docker",
      "docker_image": "your-org/your-mcp-server:latest",
      "docker_compose_file": null,
      "pip_package": null,
      "git_repo": "https://github.com/your-org/your-mcp-server",
      "start_command": [
        "docker", "run", "--rm", "--name", "mcp-example",
        "-v", "/opt/sudx-backend/data/example:/data",
        "--network", "host",
        "your-org/your-mcp-server:latest"
      ],
      "stop_signal": "SIGTERM",
      "stop_timeout_seconds": 30,
      "health_check": {
        "type": "command",
        "target": "docker inspect --format='{{.State.Running}}' mcp-example",
        "interval_seconds": 30,
        "timeout_seconds": 10,
        "retries_before_restart": 3
      },
      "port": null,
      "env": {},
      "volumes": [
        "/opt/sudx-backend/data/example:/data"
      ],
      "depends_on": [],
      "restart_policy": "on-failure",
      "max_restart_count": 10,
      "restart_backoff_base": 2.0,
      "resource_limits": {
        "memory_mb": 4096,
        "cpu_percent": null
      },
      "transport": "stdio",
      "mcp_endpoint": null,
      "tags": ["example"]
    },
    "example-pip-server": {
      "enabled": false,
      "install_method": "pip",
      "docker_image": null,
      "docker_compose_file": null,
      "pip_package": "your-mcp-server-package",
      "git_repo": null,
      "start_command": [
        "python", "-m", "your_mcp_server",
        "--host", "127.0.0.1"
      ],
      "stop_signal": "SIGTERM",
      "stop_timeout_seconds": 15,
      "health_check": {
        "type": "command",
        "target": "pgrep -f your_mcp_server",
        "interval_seconds": 30,
        "timeout_seconds": 5,
        "retries_before_restart": 3
      },
      "port": null,
      "env": {
        "EXAMPLE_API_KEY": "your-api-key-here"
      },
      "volumes": [],
      "depends_on": [],
      "restart_policy": "always",
      "max_restart_count": 10,
      "restart_backoff_base": 2.0,
      "resource_limits": {
        "memory_mb": 1024,
        "cpu_percent": null
      },
      "transport": "stdio",
      "mcp_endpoint": null,
      "tags": ["example"]
    },
    "example-sse-server": {
      "enabled": false,
      "install_method": "docker",
      "docker_image": "your-org/your-sse-mcp:latest",
      "docker_compose_file": null,
      "pip_package": null,
      "git_repo": null,
      "start_command": [
        "docker", "compose", "-f", "/opt/sudx-backend/docker-compose.example.yml",
        "up", "-d"
      ],
      "stop_signal": "SIGTERM",
      "stop_timeout_seconds": 30,
      "health_check": {
        "type": "http",
        "target": "http://localhost:12345/health",
        "interval_seconds": 30,
        "timeout_seconds": 10,
        "retries_before_restart": 3
      },
      "port": 12345,
      "env": {},
      "volumes": [],
      "depends_on": [],
      "restart_policy": "always",
      "max_restart_count": 10,
      "restart_backoff_base": 2.0,
      "resource_limits": {
        "memory_mb": 4096,
        "cpu_percent": null
      },
      "transport": "sse",
      "mcp_endpoint": "http://localhost:12345/mcp",
      "tags": ["example", "sse"]
    }
  },
  "global": {
    "log_dir": "logs",
    "state_dir": "state",
    "config_dir": "config",
    "data_dir": "data",
    "health_check_default_interval": 30,
    "max_concurrent_updates": 1,
    "api_port": 8420,
    "api_host": "0.0.0.0",
    "api_token_env": "SUDX_BACKEND_TOKEN",
    "remote_base_path": "/opt/sudx-backend",
    "venv_path": "backend/.venv",
    "ring_buffer_size": 10000,
    "metrics_persist_interval_seconds": 60,
    "event_archive_max_size_mb": 50,
    "event_archive_max_rotations": 10,
    "sse_max_clients": 10,
    "sse_heartbeat_interval_seconds": 15,
    "alert_cooldown_seconds": 300,
    "cleanup_interval_hours": 1,
    "retention_days_events": 90,
    "retention_days_logs": 14,
    "retention_days_metrics": 365
  }
}
